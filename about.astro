---
import Base from '../layouts/Base.astro';
import { milestones, people } from '../data/site.js';
---

<Base title="About Us | XGRC® Software" description="The story of XGRC Software since 2015, and the humans behind the code.">
  <section class="page-head">
    <div class="container">
      <span class="eyebrow"><span class="dot"></span>About Us</span>
      <h1>Built to make governance executable.</h1>
      <p class="lede">XGRC® Software is built and owned by Strategix. Since 2015 we have helped organisations replace fragmented oversight with one secure, auditable platform. ISO 27001:2022 certified, with a presence in Johannesburg, Cape Town and the United Kingdom.</p>
    </div>
  </section>

  <!-- Vertical timeline -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow"><span class="dot"></span>Our journey</span>
        <h2>A decade of Driving Compliance®.</h2>
      </div>
      <ol class="timeline">
        {milestones.map((m) => (
          <li class="event">
            <div class="year">{m.year}</div>
            <div class="node" aria-hidden="true"></div>
            <div class="body">
              <h3>{m.title}</h3>
              <p>{m.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Humans behind the code -->
  <section class="section--tight">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow"><span class="dot"></span>The humans behind the code</span>
        <h2>{people.length} people, one mission.</h2>
        <p class="lede">Every card is a name and a superpower. The team that builds, secures and supports the platform.</p>
      </div>
      <div class="people">
        {people.map((p) => (
          <div class="person">
            <div class="avatar" aria-hidden="true">{p.name.split(' ').map((w) => w[0]).join('').slice(0, 2)}</div>
            <div class="pname">{p.name}</div>
            <div class="power">{p.superpower}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head { padding: 130px 0 0; }
  .page-head h1 { margin: 8px 0 18px; }

  /* timeline */
  .timeline { list-style: none; position: relative; margin-left: 8px; padding-left: 40px; }
  .timeline::before { content: ""; position: absolute; left: 0; top: 6px; bottom: 6px; width: 2px;
    background: linear-gradient(180deg, var(--cyan), var(--blue) 60%, transparent); }
  .event { position: relative; padding: 0 0 36px 0; }
  .event .year { font-family: var(--font-mono); font-size: 13px; color: var(--cyan); margin-bottom: 6px; }
  .event .node { position: absolute; left: -47px; top: 2px; width: 14px; height: 14px; border-radius: 50%;
    background: var(--void); border: 2px solid var(--cyan); box-shadow: 0 0 14px rgba(48,226,244,0.6); }
  .event .body h3 { margin-bottom: 6px; }
  .event .body p { max-width: 60ch; font-size: 0.96rem; }

  /* people */
  .people { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .person { background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius-md); padding: 22px;
    display: flex; flex-direction: column; gap: 4px; transition: 0.3s var(--ease); }
  .person:hover { transform: translateY(-4px); border-color: var(--line-strong); background: var(--panel-hover); }
  .avatar { width: 46px; height: 46px; border-radius: 12px; display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-weight: 700; font-size: 15px; color: var(--green-ink);
    background: linear-gradient(135deg, var(--green), var(--cyan)); margin-bottom: 12px; }
  .pname { font-family: var(--font-display); font-weight: 600; font-size: 1.02rem; }
  .power { font-family: var(--font-mono); font-size: 11.5px; color: var(--cyan); letter-spacing: 0.03em; }

  @media (max-width: 820px) { .people { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .people { grid-template-columns: 1fr; } }
</style>
