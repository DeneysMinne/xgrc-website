---
import Base from '../../layouts/Base.astro';

const problems = [
  'Fragmented risk registers across business units',
  'Inconsistent scoring methodology and risk appetite definitions',
  'Limited visibility of risk exposure for leadership',
  'Poor linkage between risks, controls, and audit findings'
];

const approach = [
  'Define risk management framework and governance structure',
  'Identify risks across strategic, operational, financial and compliance dimensions',
  'Assess likelihood and impact using a consistent scoring model',
  'Define and assign risk treatment plans with clear ownership',
  'Monitor risk indicators and escalate critical exposures',
  'Report risk status to management and the board'
];

const howItWorks = [
  'Central risk register with consistent taxonomy',
  'Configurable scoring models and risk appetite thresholds',
  'Risk appetite and tolerance tracking',
  'Integration with controls, audits, and compliance obligations',
  'Real-time dashboards and board-ready reporting'
];

const manual = [
  'Spreadsheet-based risk tracking',
  'Inconsistent scoring across departments',
  'Manual, periodic reporting',
  'No linkage to controls or audit'
];
const withXgrc = [
  'Structured, centralised risk register',
  'Consistent framework and scoring model',
  'Real-time dashboards and automated reporting',
  'Risks linked to controls, audits, and compliance'
];

const resourceIncludes = [
  'Governance & risk framework',
  'Risk identification across all categories',
  'Risk assessment and scoring',
  'Risk treatment and action tracking',
  'Monitoring, escalation and review',
  'Reporting, integration and continuous improvement'
];

const standards = ['ISO 31000', 'COSO ERM', 'King V'];
const scope = [
  'Strategic risk',
  'Operational risk',
  'Financial risk',
  'Compliance risk'
];

const pageTitle = 'Enterprise Risk Management Software | ISO 31000 & COSO | XGRC®';
const pageDesc  = 'Enterprise risk management software to identify, assess, and manage risk. Align to ISO 31000 and COSO with XGRC®.';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      'name': 'Enterprise Risk Management Software — XGRC®',
      'serviceType': 'Enterprise Risk Management',
      'description': 'Central ERM platform to identify, assess, treat, and monitor risk across strategic, operational, financial and compliance dimensions, aligned to ISO 31000, COSO, and King V.',
      'provider': { '@type': 'Organization', 'name': 'XGRC® Software', 'url': 'https://xgrcsoftware.com' }
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home',      'item': 'https://xgrcsoftware.com/' },
        { '@type': 'ListItem', 'position': 2, 'name': 'Use Cases', 'item': 'https://xgrcsoftware.com/use-cases/' },
        { '@type': 'ListItem', 'position': 3, 'name': 'Enterprise Risk Management' }
      ]
    }
  ]
};
---
<Base title={pageTitle} description={pageDesc}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- ============ HERO ============ -->
  <section class="page-head">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span>/</span><a href="/use-cases/">Use Cases</a><span>/</span><b>Enterprise Risk Management</b>
      </nav>
      <span class="eyebrow"><span class="dot"></span>Use Case &middot; XGRC&reg; ERM</span>
      <h1>Enterprise risk management embedded in governance — not tracked in spreadsheets.</h1>
      <p class="lede">XGRC&reg; provides a central ERM platform aligned to ISO 31000, COSO, and King V. Define your risk framework, identify and assess risks across all categories, link every risk to controls and audit findings, and report to the board with real-time visibility.</p>
      <div class="hero-cta">
        <button class="btn btn-primary" data-open-download type="button">Download the ERM checklist</button>
        <a href="#demo" class="btn btn-ghost">Book a demo</a>
      </div>
    </div>
  </section>

  <!-- ============ THE PROBLEM ============ -->
  <section class="section--tight">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow"><span class="dot"></span>The problem</span>
        <h2>Fragmented risk management creates blind spots across the organisation.</h2>
        <p class="lede">When risk registers live in spreadsheets and scoring is inconsistent across teams, leadership cannot see the true risk exposure of the organisation.</p>
      </div>
      <div class="grid cols-2">
        {problems.map((p) => (
          <div class="card problem"><p>{p}</p></div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ THE XGRC APPROACH ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow"><span class="dot"></span>The XGRC&reg; approach</span>
        <h2>A structured, repeatable risk management process.</h2>
      </div>
      <div class="grid cols-3 steps">
        {approach.map((step, i) => (
          <div class="card step">
            <span class="step-no">{String(i + 1).padStart(2, '0')}</span>
            <p>{step}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="section--tight">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow"><span class="dot"></span>How it works</span>
        <h2>Built for risk owners. Visible to leadership.</h2>
      </div>
      <div class="grid cols-2 howgrid">
        <ul class="ticks">
          {howItWorks.map((h) => (<li>{h}</li>))}
        </ul>
        <div class="card platform">
          <h3>One connected view of risk</h3>
          <p>XGRC&reg; centralises the risk register, links risks to controls and internal audits, and provides real-time dashboards for leadership. Risk owners get structured workflows and action tracking. The board gets complete visibility without waiting for manual reports.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MANUAL VS XGRC ============ -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow"><span class="dot"></span>From manual to XGRC&reg;</span>
        <h2>The same risk process, without the manual overhead.</h2>
      </div>
      <div class="grid cols-2 compare">
        <div class="card col-manual">
          <span class="compare-label">Manual approach</span>
          <ul class="bars">{manual.map((m) => (<li>{m}</li>))}</ul>
        </div>
        <div class="card col-xgrc">
          <span class="compare-label">XGRC&reg; approach</span>
          <ul class="bars">{withXgrc.map((x) => (<li>{x}</li>))}</ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ DOWNLOADABLE RESOURCE (gated) ============ -->
  <section class="section--tight" id="resource">
    <div class="container">
      <div class="card resource">
        <div class="resource-body">
          <span class="eyebrow"><span class="dot"></span>Free resource</span>
          <h2>Enterprise Risk Management Checklist (ISO 31000 / COSO aligned)</h2>
          <p class="lede">A structured, ISO-aligned checklist covering the full ERM process — from governance and framework setup through risk identification, assessment, treatment, monitoring, and continuous improvement.</p>
          <ul class="ticks compact">
            {resourceIncludes.map((r) => (<li>{r}</li>))}
          </ul>
        </div>
        <div class="resource-action">
          <button class="btn btn-primary" data-open-download type="button">Download the checklist</button>
          <span class="resource-note">PDF &middot; ISO 31000 / COSO aligned &middot; v1.0</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ STANDARDS + SCOPE ============ -->
  <section class="section--tight">
    <div class="container">
      <div class="grid cols-2">
        <div>
          <span class="eyebrow"><span class="dot"></span>Standards and frameworks</span>
          <h3 class="chips-head">Manage risk against the frameworks that matter.</h3>
          <ul class="chips">{standards.map((s) => (<li>{s}</li>))}</ul>
        </div>
        <div>
          <span class="eyebrow"><span class="dot"></span>Scope of application</span>
          <h3 class="chips-head">One platform across every risk category.</h3>
          <ul class="chips">{scope.map((s) => (<li>{s}</li>))}</ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="section" id="demo">
    <div class="container">
      <div class="card cta-band">
        <h2>See how XGRC&reg; enables structured enterprise risk management.</h2>
        <p class="lede">Book a demo to see how XGRC&reg; enables structured ERM — from risk identification and assessment through to board-level reporting.</p>
        <a href="mailto:info@xgrcsoftware.com?subject=XGRC%20ERM%20Demo%20Request" class="btn btn-primary">Book a demo</a>
      </div>
    </div>
  </section>

  <!-- ============ DOWNLOAD MODAL ============ -->
  <div class="modal" id="downloadModal" hidden>
    <div class="modal-backdrop" data-close-download></div>
    <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="dlTitle">
      <button class="modal-x" data-close-download type="button" aria-label="Close">&times;</button>
      <div data-form-state>
        <span class="eyebrow"><span class="dot"></span>ERM Checklist</span>
        <h3 id="dlTitle">Where should we send your download link?</h3>
        <p>Enter your details and we will email you the link to the ISO 31000 / COSO aligned checklist.</p>
        <form id="downloadForm" novalidate>
          <label>Name<input type="text" name="name" required autocomplete="name" /></label>
          <label>Work email<input type="email" name="email" required autocomplete="email" /></label>
          <label>Company <span class="opt">(optional)</span><input type="text" name="company" autocomplete="organization" /></label>
          <p class="form-error" data-error hidden>Please enter your name and a valid email address.</p>
          <button class="btn btn-primary" type="submit">Email me the checklist</button>
          <p class="form-fine">We use your details only to send the resource and occasional XGRC&reg; updates. Unsubscribe any time.</p>
        </form>
      </div>
      <div data-success-state hidden>
        <span class="eyebrow ok"><span class="dot"></span>On its way</span>
        <h3>Thank you. Check your inbox.</h3>
        <p>We have sent the download link for the Enterprise Risk Management Checklist to your email. If it does not arrive in a few minutes, check your spam folder.</p>
        <button class="btn btn-ghost" data-close-download type="button">Close</button>
      </div>
    </div>
  </div>
</Base>

<script>
  const modal = document.getElementById('downloadModal');
  const form = document.getElementById('downloadForm');
  const formState = modal?.querySelector('[data-form-state]');
  const successState = modal?.querySelector('[data-success-state]');
  const errorEl = modal?.querySelector('[data-error]');
  let lastFocused = null;

  function openModal() {
    lastFocused = document.activeElement;
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    modal.querySelector('input[name="name"]')?.focus({ preventScroll: true });
  }
  function closeModal() {
    modal.hidden = true;
    document.body.style.overflow = '';
    formState.hidden = false;
    successState.hidden = true;
    form?.reset();
    errorEl.hidden = true;
    lastFocused?.focus();
  }

  document.querySelectorAll('[data-open-download]').forEach((b) => b.addEventListener('click', openModal));
  document.querySelectorAll('[data-close-download]').forEach((b) => b.addEventListener('click', closeModal));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal.hidden) closeModal(); });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = (data.get('name') || '').toString().trim();
    const email = (data.get('email') || '').toString().trim();
    const validEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    if (!name || !validEmail) { errorEl.hidden = false; return; }
    errorEl.hidden = true;
    // INTEGRATION POINT — replace with HubSpot / form service submit
    formState.hidden = true;
    successState.hidden = false;
  });
</script>

<style>
  .page-head { padding: 130px 0 0; }
  .page-head h1 { margin: 8px 0 18px; max-width: 22ch; }
  .crumbs { font-family: var(--font-mono); font-size: 11.5px; letter-spacing: 0.06em; color: var(--faint); display: flex; gap: 10px; align-items: center; margin-bottom: 26px; }
  .crumbs a { color: var(--mute); text-decoration: none; }
  .crumbs a:hover { color: var(--cyan); }
  .crumbs b { color: var(--ink); font-weight: 500; }
  .hero-cta { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 30px; }

  .problem p { color: var(--ink); font-size: 1rem; }
  .problem::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--blue); opacity: 0.55; }

  .steps .step { display: flex; gap: 16px; align-items: flex-start; }
  .step-no { font-family: var(--font-mono); font-size: 13px; font-weight: 700; color: var(--cyan); border: 1px solid var(--line-strong); border-radius: 8px; padding: 5px 9px; background: rgba(48,226,244,0.06); flex: none; }
  .step p { color: var(--ink); font-size: 0.98rem; }

  .howgrid { align-items: start; }
  .ticks { list-style: none; display: grid; gap: 14px; }
  .ticks li { position: relative; padding-left: 30px; color: var(--ink); }
  .ticks li::before { content: ""; position: absolute; left: 0; top: 7px; width: 14px; height: 14px; border-radius: 4px; border: 2px solid var(--cyan); }
  .ticks.compact li { font-size: 0.95rem; }
  .platform { background: linear-gradient(120deg, rgba(48,226,244,0.06), rgba(38,158,198,0.02)); border-color: var(--line-strong); }
  .platform h3 { margin-bottom: 10px; }

  .compare-label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; display: inline-block; margin-bottom: 16px; }
  .col-manual .compare-label { color: var(--faint); }
  .col-xgrc { border-color: var(--line-strong); background: linear-gradient(120deg, rgba(48,226,244,0.05), transparent); }
  .col-xgrc .compare-label { color: var(--cyan); }
  .bars { list-style: none; display: grid; gap: 12px; }
  .bars li { padding: 11px 14px; border-radius: var(--radius-sm); font-size: 0.95rem; }
  .col-manual .bars li { background: rgba(255,255,255,0.03); color: var(--mute); border: 1px solid var(--line); }
  .col-xgrc .bars li { background: rgba(48,226,244,0.06); color: var(--ink); border: 1px solid var(--line-strong); }

  .resource { display: flex; gap: 36px; align-items: center; justify-content: space-between; flex-wrap: wrap; background: linear-gradient(120deg, rgba(38,158,198,0.07), rgba(48,226,244,0.02)); border-color: var(--line-strong); }
  .resource-body { flex: 1 1 360px; }
  .resource-body h2 { margin: 4px 0 10px; font-size: clamp(1.5rem, 2.4vw, 2rem); }
  .resource-action { display: flex; flex-direction: column; align-items: flex-start; gap: 12px; }
  .resource-note { font-family: var(--font-mono); font-size: 11px; color: var(--faint); letter-spacing: 0.06em; }

  .chips-head { margin-bottom: 18px; max-width: 24ch; }
  .chips { list-style: none; display: flex; flex-wrap: wrap; gap: 10px; }
  .chips li { font-family: var(--font-mono); font-size: 12px; color: var(--cyan); border: 1px solid var(--line); border-radius: 100px; padding: 8px 15px; background: rgba(48,226,244,0.05); }

  .cta-band { text-align: center; padding: clamp(40px, 6vw, 64px); background: linear-gradient(120deg, rgba(48,226,244,0.06), rgba(0,92,169,0.05)); border-color: var(--line-strong); }
  .cta-band .lede { margin: 0 auto 26px; }

  .modal { position: fixed; inset: 0; z-index: 100; display: flex; align-items: center; justify-content: center; padding: 20px; }
  .modal[hidden] { display: none; }
  .modal-backdrop { position: absolute; inset: 0; background: rgba(3, 8, 15, 0.72); backdrop-filter: blur(4px); }
  .modal-card { position: relative; width: 100%; max-width: 440px; background: var(--abyss); border: 1px solid var(--line-strong); border-radius: var(--radius-lg); padding: clamp(26px, 4vw, 34px); }
  .modal-x { position: absolute; top: 14px; right: 16px; background: none; border: none; color: var(--mute); font-size: 26px; line-height: 1; cursor: pointer; }
  .modal-x:hover { color: var(--ink); }
  .modal-card h3 { margin-bottom: 8px; }
  .modal-card form { display: grid; gap: 14px; margin-top: 20px; }
  .modal-card label { display: grid; gap: 6px; font-size: 0.85rem; color: var(--mute); font-family: var(--font-body); }
  .modal-card .opt { color: var(--faint); }
  .modal-card input { background: rgba(255,255,255,0.04); border: 1px solid var(--line); border-radius: var(--radius-sm); padding: 11px 13px; color: var(--ink); font-family: var(--font-body); font-size: 15px; }
  .modal-card input:focus { outline: none; border-color: var(--cyan); }
  .modal-card .btn { width: 100%; justify-content: center; }
  .form-error { color: #ff8a8a; font-size: 0.85rem; }
  .form-fine { font-size: 0.75rem; color: var(--faint); line-height: 1.5; }
  .eyebrow.ok { color: var(--green); border-color: rgba(47,232,138,0.3); background: rgba(47,232,138,0.06); }
  .eyebrow.ok .dot { background: var(--green); box-shadow: 0 0 9px var(--green); }

  @media (max-width: 700px) {
    .resource { flex-direction: column; align-items: flex-start; }
    .resource-action { width: 100%; }
  }
</style>
