---
import Base from '../layouts/Base.astro';
const docs = [
  { title: 'Privacy Policy', note: 'How personal information is collected, used and protected, aligned to POPIA and GDPR.' },
  { title: 'End User Licence Agreement (EULA)', note: 'Terms governing use of the XGRC® platform.' },
  { title: 'SaaS Agreement', note: 'Service terms, availability and support commitments for the hosted platform.' },
  { title: 'Data Processing & POPIA / GDPR', note: 'Data handling, customer-specific encryption keys, and the Data Destruction Certificate at end of partnership.' },
  { title: 'ISO 27001:2022 Certification', note: 'Independent certification of the Information Security Management System.' }
];
---

<Base title="Legal Hub | XGRC® Software" description="Privacy, EULA, SaaS terms, data protection and certifications for the XGRC platform.">
  <section class="page-head">
    <div class="container">
      <span class="eyebrow"><span class="dot"></span>Legal Hub</span>
      <h1>Trust, in writing.</h1>
      <p class="lede">The agreements, policies and certifications that govern the XGRC® platform. Security and privacy are designed in, validated by ISO 27001:2022.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid cols-2">
        {docs.map((d) => (
          <div class="card">
            <h3>{d.title}</h3>
            <p>{d.note}</p>
            <a href="#" class="link-arrow">Read →</a>
          </div>
        ))}
      </div>
      <p class="note">Paste the verbatim legal text into each document page when ready. The live source is the current Privacy Policy &amp; EULA page.</p>
    </div>
  </section>
</Base>

<style>
  .page-head { padding: 130px 0 0; }
  .page-head h1 { margin: 8px 0 18px; }
  .card .link-arrow { display: inline-block; margin-top: 14px; }
  .note { font-size: 0.85rem; color: var(--faint); margin-top: 28px; }
</style>
