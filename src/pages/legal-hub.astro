  .tp-amber { color: #f6c560; border-color: rgba(246,197,96,0.4); } .tp-red { color: #f08585; border-color: rgba(240,133,133,0.4); } .tp-blue { color: #6db8e0; border-color: rgba(109,184,224,0.4); }
  .trigger-steps { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .trigger-steps li { font-size: 0.92rem; color: var(--mute); padding-left: 18px; position: relative; }
  .trigger-steps li::before { content: ""; position: absolute; left: 0; top: 9px; width: 6px; height: 6px; border-radius: 50%; background: var(--cyan); }

  /* renewal */
  .renewal-flow { display: flex; align-items: stretch; gap: 8px; flex-wrap: wrap; margin-bottom: 32px; }
