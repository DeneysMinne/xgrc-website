---
// Home hero: the "Living Architecture" network rendered on canvas.
// Green = action (CTAs). Cyan/blue = the system.
---

<section class="hero">
  <canvas id="xgrcNet" aria-hidden="true"></canvas>
  <div class="scrim" aria-hidden="true"></div>

  <div class="container hero-content">
    <div class="hero-copy">
      <span class="eyebrow"><span class="dot"></span>XGRC Software · by Strategix</span>
      <h1>Connected<br><span class="grad">Governance</span> Architecture</h1>
      <p class="hero-sub">See every risk, control and obligation in one auditable place — and act before issues become incidents.</p>
      <p class="lede">Governance, risk, compliance and cyber security, wired into one secure, auditable platform. Every solution talks to the next, so your four lines of defence finally act as one.</p>
      <div class="actions">
        <a href="/demo" class="btn btn-primary">Book a demo</a>
        <a href="/solutions" class="btn btn-ghost">Explore solutions</a>
      </div>
      <div class="telemetry">
        <span><span class="led"></span>FOUR LINES OF DEFENCE <b>SYNCED</b></span>
        <span>AUDIT TRAIL <b>LIVE</b></span>
        <span>ISO 27001 · ISO 9001 · KING IV</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero { position: relative; min-height: 92vh; display: flex; align-items: center; overflow: hidden; }
  #xgrcNet { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .scrim { position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(95deg, rgba(6,15,28,0.97) 0%, rgba(6,15,28,0.92) 40%, rgba(6,15,28,0.55) 60%, rgba(6,15,28,0) 80%); }
  @media (max-width: 860px) { .scrim { background: linear-gradient(180deg, rgba(6,15,28,0.45) 0%, rgba(6,15,28,0.86) 62%); } }

  .hero-content { position: relative; z-index: 2; }
  .hero-copy { max-width: 640px; padding-top: 90px; padding-bottom: 40px; }
  h1 { margin-bottom: 22px; }
  .grad { background: linear-gradient(100deg, var(--cyan-hi), var(--cyan) 40%, var(--blue)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .hero-sub { font-size: clamp(1.05rem, 1.5vw, 1.22rem); color: var(--ink); font-weight: 500; margin-bottom: 14px; max-width: 52ch; line-height: 1.5; }
  .lede { margin-bottom: 34px; }
  .actions { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 40px; }
  .telemetry { display: flex; gap: 24px; flex-wrap: wrap; font-family: var(--font-mono); font-size: 11px; color: var(--faint); letter-spacing: 0.04em; }
  .telemetry b { color: var(--cyan); font-weight: 500; }
  .led { width: 6px; height: 6px; border-radius: 50%; background: var(--green); box-shadow: 0 0 8px var(--green); display: inline-block; margin-right: 7px; }
  .eyebrow .dot { animation: beat 2.4s infinite ease-in-out; }
  @keyframes beat { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.35; transform: scale(0.7); } }
</style>

<script>
  (function () {
    const canvas = document.getElementById('xgrcNet');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let W = 0, H = 0, DPR = 1;

    const HUB = { name: 'XGRC', desc: 'Connected governance core', hub: true };
    const MODULES = [
      { name: 'SHEQX', desc: 'Safety, Health, Environment, Quality', ang: 270, r: 1.05 },
      { name: 'ENVIRX', desc: 'Environmental compliance & monitoring', ang: 300, r: 0.92 },
      { name: 'ESG', desc: 'Environmental, Social, Governance', ang: 330, r: 1.05 },
      { name: 'MSX', desc: 'Integrated management system', ang: 0, r: 0.90 },
      { name: 'MSXCyber', desc: 'ISO 27001 information security', ang: 30, r: 1.10 },
      { name: 'ERM', desc: 'Enterprise Risk Management', ang: 60, r: 0.88 },
      { name: 'Assurance', desc: 'Integrated assurance & audit', ang: 90, r: 1.08 },
      { name: 'Compliance', desc: 'Supplier & third-party compliance', ang: 120, r: 0.92 },
      { name: 'XLOGIC', desc: 'Supplier onboarding & vetting', ang: 150, r: 1.06 },
      { name: 'MAIA', desc: 'Governed AI for GRC', ang: 180, r: 0.90 },
      { name: 'Libryo', desc: 'Regulatory intelligence (partner)', ang: 210, r: 1.12 },
      { name: 'Hakware', desc: 'Cyber risk awareness (partner)', ang: 240, r: 0.95 }
    ];
    const nodes = [HUB, ...MODULES].map((n, i) => ({ ...n, i, phase: Math.random() * Math.PI * 2, x: 0, y: 0, bx: 0, by: 0 }));

    const edges = [];
    for (let i = 1; i < nodes.length; i++) edges.push([0, i, 1]);
    const rim = [['SHEQX', 'ENVIRX'], ['ENVIRX', 'ESG'], ['MSXCyber', 'Hakware'], ['MAIA', 'ERM'], ['Assurance', 'ERM'], ['Compliance', 'XLOGIC'], ['MSX', 'MAIA']];
    const idx = (name) => nodes.findIndex((n) => n.name === name);
    rim.forEach(([a, b]) => edges.push([idx(a), idx(b), 0]));

    const pulses = [];
    function spawnPulse() {
      if (reduce) return;
      const e = edges[(Math.random() * edges.length) | 0];
      pulses.push({ e, t: 0, sp: 0.0024 + Math.random() * 0.0026 });
      if (pulses.length > 30) pulses.shift();
    }

    const mouse = { x: 0.5, y: 0.5, tx: 0.5, ty: 0.5 };
    let hover = -1;

    function resize() {
      DPR = Math.min(window.devicePixelRatio || 1, 2);
      const rect = canvas.getBoundingClientRect();
      W = rect.width; H = rect.height;
      canvas.width = W * DPR; canvas.height = H * DPR;
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      layout();
    }
    function layout() {
      const narrow = W < 860;
      const cx = W * (narrow ? 0.5 : 0.74);
      const cy = H * (narrow ? 0.4 : 0.5);
      const R = Math.min(W, H) * (narrow ? 0.34 : 0.25);
      nodes[0].bx = cx; nodes[0].by = cy;
      for (let i = 1; i < nodes.length; i++) {
        const m = nodes[i]; const a = m.ang * Math.PI / 180;
        m.bx = cx + Math.cos(a) * R * m.r; m.by = cy + Math.sin(a) * R * m.r;
      }
    }
    const lerp = (a, b, t) => a + (b - a) * t;

    function tick(time) {
      mouse.x = lerp(mouse.x, mouse.tx, 0.07); mouse.y = lerp(mouse.y, mouse.ty, 0.07);
      const px = (mouse.x - 0.5) * (reduce ? 0 : 24), py = (mouse.y - 0.5) * (reduce ? 0 : 24);
      for (const n of nodes) {
        const drift = reduce ? 0 : 6;
        n.x = n.bx + px * (n.hub ? 0.35 : 1) + Math.sin(time * 0.0004 + n.phase) * drift;
        n.y = n.by + py * (n.hub ? 0.35 : 1) + Math.cos(time * 0.00035 + n.phase) * drift;
      }
      ctx.clearRect(0, 0, W, H);

      for (const [a, b, type] of edges) {
        const na = nodes[a], nb = nodes[b];
        const lit = hover > -1 && (a === hover || b === hover);
        const g = ctx.createLinearGradient(na.x, na.y, nb.x, nb.y);
        if (type === 1) { g.addColorStop(0, 'rgba(48,226,244,' + (lit ? 0.55 : 0.14) + ')'); g.addColorStop(1, 'rgba(38,158,198,' + (lit ? 0.45 : 0.06) + ')'); }
        else { g.addColorStop(0, 'rgba(38,158,198,' + (lit ? 0.4 : 0.07) + ')'); g.addColorStop(1, 'rgba(48,226,244,' + (lit ? 0.4 : 0.07) + ')'); }
        ctx.strokeStyle = g; ctx.lineWidth = lit ? 1.6 : 1;
        ctx.beginPath(); ctx.moveTo(na.x, na.y); ctx.lineTo(nb.x, nb.y); ctx.stroke();
      }

      for (const p of pulses) {
        p.t += p.sp; const a = nodes[p.e[0]], b = nodes[p.e[1]];
        if (p.t > 1) continue;
        const x = lerp(a.x, b.x, p.t), y = lerp(a.y, b.y, p.t), fade = Math.sin(p.t * Math.PI);
        ctx.beginPath(); ctx.arc(x, y, 2.4, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(122,243,255,' + (0.9 * fade) + ')';
        ctx.shadowColor = 'rgba(48,226,244,.9)'; ctx.shadowBlur = 10; ctx.fill(); ctx.shadowBlur = 0;
      }
      for (let i = pulses.length - 1; i >= 0; i--) if (pulses[i].t > 1) pulses.splice(i, 1);

      nodes.forEach((n, i) => {
        const isHub = n.hub, isHover = i === hover;
        const baseR = isHub ? 16 : 7.5, r = baseR * (isHover ? 1.25 : 1);
        const grd = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, r * 4.5);
        grd.addColorStop(0, 'rgba(48,226,244,' + (isHub ? 0.32 : (isHover ? 0.4 : 0.14)) + ')');
        grd.addColorStop(1, 'rgba(48,226,244,0)');
        ctx.fillStyle = grd; ctx.beginPath(); ctx.arc(n.x, n.y, r * 4.5, 0, Math.PI * 2); ctx.fill();
        ctx.beginPath(); ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
        ctx.fillStyle = isHub ? '#0a1729' : '#08131f'; ctx.fill();
        ctx.lineWidth = isHub ? 2 : 1.4;
        ctx.strokeStyle = isHub ? 'rgba(122,243,255,.95)' : (isHover ? 'rgba(122,243,255,.95)' : 'rgba(48,226,244,.5)');
        ctx.stroke();
        if (isHub) { ctx.beginPath(); ctx.arc(n.x, n.y, r * 0.42, 0, Math.PI * 2); ctx.fillStyle = 'rgba(122,243,255,.9)'; ctx.fill(); }
        ctx.font = (isHover || isHub ? '600 ' : '400 ') + (isHub ? 13 : 11) + "px 'JetBrains Mono', monospace";
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillStyle = isHub ? 'rgba(234,243,247,.95)' : (isHover ? 'rgba(234,243,247,.98)' : 'rgba(132,153,170,.82)');
        ctx.fillText(n.name, n.x, n.y + r + 15);
        if (isHover && !isHub) { ctx.font = "400 10.5px 'JetBrains Mono', monospace"; ctx.fillStyle = 'rgba(48,226,244,.85)'; ctx.fillText(n.desc, n.x, n.y + r + 30); }
      });
      requestAnimationFrame(tick);
    }

    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      const mx = e.clientX - rect.left, my = e.clientY - rect.top;
      mouse.tx = mx / W; mouse.ty = my / H;
      let best = -1, bd = 28;
      for (let i = 0; i < nodes.length; i++) {
        const d = Math.hypot(mx - nodes[i].x, my - nodes[i].y);
        if (d < bd) { bd = d; best = i; }
      }
      hover = best; canvas.style.cursor = best > -1 ? 'pointer' : 'default';
    });
    canvas.addEventListener('mouseleave', () => { mouse.tx = 0.5; mouse.ty = 0.5; hover = -1; });
    window.addEventListener('resize', resize);

    resize();
    if (!reduce) { setInterval(spawnPulse, 360); for (let k = 0; k < 10; k++) spawnPulse(); }
    requestAnimationFrame(tick);
  })();
</script>
