  { file: 'CLINGLOBAL.png',         name: 'Clinglobal' },
  { file: 'OVERBERG.jpg',           name: 'Overberg' },
  { file: 'Rosh-Pinah-Zinc.jpg',    name: 'Rosh Pinah Zinc' },
  { file: 'WOODLANDS.jpg',          name: 'Woodlands' },
];

// Deterministic scatter across a 7-col × 6-row grid with prime-jitter
function scatter(i: number) {
  const cols = 7, total = logos.length;
  const col = i % cols, row = Math.floor(i / cols);
  const maxRow = Math.ceil(total / cols) - 1;

  const xMin = 5, xMax = 92, yMin = 14, yMax = 83;
  const baseX = xMin + (col / (cols - 1)) * (xMax - xMin);
  const baseY = yMin + (row / maxRow) * (yMax - yMin);
  const jx = ((i * 127 + col * 31) % 100 - 50) * 0.055;
  const jy = ((i * 89  + row * 47) % 100 - 50) * 0.055;

  // depth 1 = foreground (large, bright), depth 4 = background (small, dim)
  const depth = ((i * 3 + col * 2 + row) % 4) + 1;

  // 8 drift patterns; duration varies by depth so layers move at different rates
  const driftIdx = i % 8;
  const baseDur  = [28, 38, 50, 64][depth - 1];
  const dur      = baseDur + (i * 7) % 20;
  // Negative delay starts animation mid-cycle so logos don't all sync at page load
  const driftDelay = -((i * 13) % dur);

  return {
    x: Math.max(xMin, Math.min(xMax, baseX + jx)).toFixed(1),
    y: Math.max(yMin, Math.min(yMax, baseY + jy)).toFixed(1),
    depth,
    driftIdx,
    dur,
    driftDelay,
    delay: (i * 0.04).toFixed(2),
  };
}
---

<section id="galaxyOuter" class="galaxy-outer" aria-label="Trusted by industry leaders">
  <div id="galaxySticky" class="galaxy-sticky">

    <!-- Atmosphere glow (radial, behind everything) -->
    <div id="galaxyGlow" class="galaxy-glow" aria-hidden="true"></div>

    <!-- Portal stage: XGRC cube + label -->
    <div id="galaxyKeyhole" class="galaxy-keyhole" aria-hidden="true">
      <img src="/assets/xgrc-cube.png" alt="" class="galaxy-cube" draggable="false" />
      <span class="unlock-label">UNLOCK NETWORK</span>
    </div>

    <!-- Constellation: logos + CTA -->
    <div id="galaxyConst" class="galaxy-constellation">
      <span class="eyebrow const-eyebrow"><span class="dot"></span>Trusted by industry leaders</span>

      {logos.map((logo, i) => {
        const p = scatter(i);
        return (
          <div
            class="star"
            style={`left:${p.x}%;top:${p.y}%;--delay:${p.delay}s;--drift-anim:drift-${p.driftIdx};--drift-dur:${p.dur}s;--drift-delay:${p.driftDelay}s`}
            data-depth={p.depth}
          >
            <img
              src={`/assets/logos/customers/${logo.file}`}
              alt={logo.name}
              class="star-img"
              loading="lazy"
              draggable="false"
            />
          </div>
        );
      })}

      <a href="/use-cases" class="link-arrow const-cta">
        See how they use XGRC&reg; &rarr;
      </a>
    </div>

  </div>
</section>

<script>
(function () {
  const outer   = document.getElementById('galaxyOuter')  as HTMLElement;
  const sticky  = document.getElementById('galaxySticky') as HTMLElement;
  const glow    = document.getElementById('galaxyGlow')   as HTMLElement;
  const keyhole = document.getElementById('galaxyKeyhole') as HTMLElement;
  const constEl = document.getElementById('galaxyConst')  as HTMLElement;
  const stars   = Array.from(document.querySelectorAll<HTMLElement>('.star'));

  if (!outer || !sticky) return;

  const isReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isCoarse  = window.matchMedia('(pointer: coarse)').matches;
  const isMobile  = () => window.innerWidth < 768;

  // Portal inner dimensions: fits cube (130px) + gap (22px) + label (20px) + padding
  const PORTAL_W = 270;  // px
  const PORTAL_H = 210;  // px
  const PORTAL_R = 14;   // border-radius px

  // ── Static / reduced-motion fallback ─────────────────────────
  if (isReduced || isMobile()) {
    sticky.classList.add('is-static');
    stars.forEach(s => s.classList.add('star--in'));
    return;
  }

  let constellationShown = false;

  function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }
  function ease(t: number) { return t < 0.5 ? 2*t*t : 1 - Math.pow(-2*t+2, 2)/2; }

  function onScroll() {
    const rect      = outer.getBoundingClientRect();
    const outerH    = outer.offsetHeight;
    const vh        = window.innerHeight;
    const vw        = window.innerWidth;
    const p         = Math.max(0, Math.min(1, -rect.top / (outerH - vh)));

    const maxV = (vh - PORTAL_H) / 2;
    const maxH = (vw - PORTAL_W) / 2;

    // Portal: starts closed (small rectangle), opens fully by p=0.55
    const expandT = ease(Math.max(0, Math.min(1, p / 0.55)));
    const vInset  = lerp(maxV, 0, expandT);
    const hInset  = lerp(maxH, 0, expandT);
    const radius  = lerp(PORTAL_R, 0, expandT);

    sticky.style.clipPath = `inset(${vInset.toFixed(1)}px ${hInset.toFixed(1)}px round ${radius.toFixed(1)}px)`;

    // Portal glow fades as it expands (drop-shadow on clip boundary)
    const glowStr = expandT < 0.95
      ? `drop-shadow(0 0 ${lerp(22, 4, expandT).toFixed(0)}px rgba(48,226,244,${lerp(0.75, 0, expandT).toFixed(2)})) drop-shadow(0 0 ${lerp(60, 10, expandT).toFixed(0)}px rgba(38,158,198,${lerp(0.40, 0, expandT).toFixed(2)}))`
      : 'none';
    sticky.style.filter = glowStr;

    // Background atmosphere glow fades in then stays
    glow.style.opacity = String(Math.min(1, p / 0.25));

    // Keyhole: fade in 0→0.12, hold, fade out 0.32→0.52
    let kp: number;
    if      (p < 0.12) kp = p / 0.12;
    else if (p < 0.32) kp = 1;
    else if (p < 0.52) kp = 1 - (p - 0.32) / 0.20;
    else               kp = 0;
    keyhole.style.opacity = String(kp);

    // Logos: reveal once portal is fully open
    if (p >= 0.55 && !constellationShown) {
      constellationShown = true;
      constEl.classList.add('is-visible');
      stars.forEach((star, i) => {
        setTimeout(() => star.classList.add('star--in'), i * 38);
      });
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ── Mouse parallax ────────────────────────────────────────────
  if (!isCoarse) {
    let rafId = 0;
    let mx = 0, my = 0;

    sticky.addEventListener('pointermove', (e: PointerEvent) => {
      if (!constellationShown) return;
      const r  = sticky.getBoundingClientRect();
      mx = (e.clientX - r.left  - r.width  / 2) / (r.width  / 2);
      my = (e.clientY - r.top   - r.height / 2) / (r.height / 2);
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(() => {
        stars.forEach(star => {
          const d = parseInt(star.dataset.depth ?? '1', 10);
          star.style.setProperty('--px', `${(mx * d * 12).toFixed(1)}px`);
          star.style.setProperty('--py', `${(my * d *  9).toFixed(1)}px`);
        });
      });
    });

    sticky.addEventListener('pointerleave', () => {
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(() => {
        stars.forEach(star => {
          star.style.setProperty('--px', '0px');
          star.style.setProperty('--py', '0px');
        });
      });
    });
  }

  window.addEventListener('resize', () => {
    if (isMobile()) {
      sticky.style.clipPath = '';
      sticky.style.filter   = '';
      sticky.classList.add('is-static');
      constEl.classList.add('is-visible');
      stars.forEach(s => s.classList.add('star--in'));
    }
  }, { passive: true });
})();
</script>

<style>
  /* ── 8 autonomous drift patterns ────────────────────────────
     Applied to .star-img so they compose cleanly with
     the parallax translate on the parent .star element.      */
  @keyframes drift-0 {
    0%   { transform: translate(  0px,   0px); }
    20%  { transform: translate( 14px,  -9px); }
    40%  { transform: translate(  7px,  17px); }
    60%  { transform: translate(-11px,   8px); }
    80%  { transform: translate( -5px, -13px); }
    100% { transform: translate(  0px,   0px); }
  }
  @keyframes drift-1 {
    0%   { transform: translate(  0px,   0px); }
    25%  { transform: translate(-16px,  -7px); }
    50%  { transform: translate( -9px,  15px); }
    75%  { transform: translate( 11px,   6px); }
    100% { transform: translate(  0px,   0px); }
  }
  @keyframes drift-2 {
    0%   { transform: translate(  0px,   0px); }
    33%  { transform: translate( 18px,  10px); }
    66%  { transform: translate(-13px,   6px); }
    100% { transform: translate(  0px,   0px); }
  }
  @keyframes drift-3 {
    0%   { transform: translate(  0px,   0px); }
    20%  { transform: translate(  9px, -17px); }
    50%  { transform: translate( 17px,  -4px); }
    80%  { transform: translate(  5px,  13px); }
    100% { transform: translate(  0px,   0px); }
  }
  @keyframes drift-4 {
    0%   { transform: translate(  0px,   0px); }
    30%  { transform: translate(-13px,  15px); }
    60%  { transform: translate(  7px,  19px); }
    100% { transform: translate(  0px,   0px); }
  }
  @keyframes drift-5 {
    0%   { transform: translate(  0px,   0px); }
    25%  { transform: translate(-18px,   5px); }
    50%  { transform: translate(-11px, -13px); }
    75%  { transform: translate(  4px,  -8px); }
    100% { transform: translate(  0px,   0px); }
  }
  @keyframes drift-6 {
    0%   { transform: translate(  0px,   0px); }
    40%  { transform: translate( 11px, -19px); }
    70%  { transform: translate( -8px, -10px); }
    100% { transform: translate(  0px,   0px); }
  }
  @keyframes drift-7 {
    0%   { transform: translate(  0px,   0px); }
    20%  { transform: translate( -7px, -15px); }
    40%  { transform: translate( 16px, -10px); }
    60%  { transform: translate( 13px,  11px); }
    80%  { transform: translate( -5px,   9px); }
    100% { transform: translate(  0px,   0px); }
  }

  @keyframes cube-pulse {
    0%, 100% {
      filter: drop-shadow(0 0 18px rgba(48,226,244,0.45)) drop-shadow(0 0 40px rgba(38,158,198,0.30));
      transform: scale(1);
    }
    50% {
      filter: drop-shadow(0 0 36px rgba(48,226,244,0.80)) drop-shadow(0 0 80px rgba(38,158,198,0.50));
      transform: scale(1.06);
    }
  }

  /* ── Outer scroll container ──────────────────────────────── */
  .galaxy-outer {
    position: relative;
    height: 220vh;
    background: var(--abyss, #060f1c);
  }

  /* ── Sticky viewport — starts as a small portal ──────────── */
  .galaxy-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    background: var(--abyss, #060f1c);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Initial portal clip (JS overrides on scroll).
       inset %: top/bottom relative to height, left/right to width.
       50% - 105px = half-viewport minus half-portal-height (210/2).
       50% - 135px = half-viewport minus half-portal-width  (270/2). */
    clip-path: inset(calc(50% - 105px) calc(50% - 135px) round 14px);
    filter:
      drop-shadow(0 0 22px rgba(48,226,244,0.75))
      drop-shadow(0 0 60px rgba(38,158,198,0.40));
    will-change: clip-path, filter;
  }

  /* ── Atmosphere glow ─────────────────────────────────────── */
  .galaxy-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 62% 55% at center, rgba(38,158,198,0.18) 0%, rgba(38,158,198,0.06) 42%, transparent 68%),
      radial-gradient(ellipse 26% 22% at center, rgba(48,226,244,0.24) 0%, transparent 56%);
    opacity: 0;
    pointer-events: none;
    z-index: 1;
  }

  /* ── Portal stage ────────────────────────────────────────── */
  .galaxy-keyhole {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 22px;
    opacity: 0;
    z-index: 3;
    pointer-events: none;
  }
  .galaxy-cube {
    width: 130px;
    height: 130px;
    object-fit: contain;
    animation: cube-pulse 2.6s ease-in-out infinite;
  }
  .unlock-label {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--cyan, #30e2f4);
    opacity: 0.85;
  }

  /* ── Constellation container ─────────────────────────────── */
  .galaxy-constellation {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
    z-index: 2;
  }
  .galaxy-constellation.is-visible { opacity: 1; }

  .const-eyebrow {
    position: absolute;
    top: 26px;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.8s ease 0.5s;
  }
  .is-visible .const-eyebrow { opacity: 1; }

  .const-cta {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.8s ease 1.1s;
  }
  .is-visible .const-cta { opacity: 1; }

  /* ── Depth: scale + opacity + glow size ─────────────────── */
  .star[data-depth="1"] { --star-scale: 1.30; --star-opacity: 1.0;  --glow-r: 52px; --glow-a: 0.50; }
  .star[data-depth="2"] { --star-scale: 1.00; --star-opacity: 0.85; --glow-r: 38px; --glow-a: 0.32; }
  .star[data-depth="3"] { --star-scale: 0.72; --star-opacity: 0.62; --glow-r: 26px; --glow-a: 0.18; }
  .star[data-depth="4"] { --star-scale: 0.50; --star-opacity: 0.38; --glow-r: 16px; --glow-a: 0.10; }

  /* ── Individual logo stars ───────────────────────────────── */
  .star {
    position: absolute;
    transform: translate(calc(-50% + var(--px, 0px)), calc(-50% + var(--py, 0px)))
               scale(var(--star-scale, 1));
    opacity: 0;
    transition:
      transform 0.14s ease-out,
      opacity   0.7s ease var(--delay, 0s);
    z-index: 0;
  }
  .star.star--in { opacity: var(--star-opacity, 1); }
  .star:hover    {
    z-index: 10;
    transform: translate(calc(-50% + var(--px, 0px)), calc(-50% + var(--py, 0px)))
               scale(calc(var(--star-scale, 1) * 1.18));
    /* Override glow vars — cascades to ::before */
    --glow-a: 0.85;
    --glow-r: 62px;
  }

  /* Ambient glow — the "starlight" around each logo.
     Opacity is driven by --glow-a so it transitions smoothly on hover.
     White JPG backgrounds blend into the bright glow center. */
  .star::before {
    content: '';
    position: absolute;
    inset: calc(-1 * var(--glow-r, 40px));
    border-radius: 50%;
    background: radial-gradient(
      circle at center,
      rgba(48, 226, 244, 0.55) 0%,
      rgba(38, 158, 198, 0.32) 42%,
      transparent 72%
    );
    opacity: var(--glow-a, 0.25);
    pointer-events: none;
    z-index: -1;
    transition: opacity 0.3s ease, inset 0.3s ease;
  }

  /* Logo image — full colour, autonomous slow drift */
  .star-img {
    display: block;
    max-width: 88px;
    max-height: 40px;
    object-fit: contain;
    border-radius: 4px;
    animation: var(--drift-anim, drift-0) var(--drift-dur, 45s) ease-in-out infinite var(--drift-delay, 0s);
  }
  .star:hover .star-img {
    animation-play-state: paused;
    filter: drop-shadow(0 0 8px rgba(48, 226, 244, 0.55));
  }

  /* ── Static / reduced-motion layout ─────────────────────── */
  .is-static.galaxy-sticky {
    position: relative;
    height: auto;
    padding: 64px 0 56px;
    clip-path: none !important;
    filter: none !important;
  }
  .galaxy-outer:has(.is-static) { height: auto; }
  .is-static .galaxy-glow { opacity: 0.6; }
  .is-static .galaxy-keyhole { display: none; }
  .is-static .galaxy-constellation {
    position: relative;
    opacity: 1;
    padding: 48px var(--container-pad, 5vw);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }
  .is-static .const-eyebrow {
    position: relative; left: auto; transform: none; opacity: 1;
    width: 100%; text-align: center; margin-bottom: 20px;
  }
  .is-static .const-cta {
    position: relative; bottom: auto; left: auto; transform: none; opacity: 1;
    width: 100%; text-align: center; margin-top: 20px;
  }
  .is-static .star {
    position: relative;
    left: auto !important; top: auto !important;
    transform: none; opacity: 1;
  }
  .is-static .star::before { display: none; }
  .is-static .star-img { animation: none; }

  /* ── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .galaxy-outer { height: auto; }
    .galaxy-sticky {
      position: relative; height: auto;
      padding: 56px 0 48px;
      clip-path: none !important; filter: none !important;
    }
    .galaxy-glow { opacity: 0.5; }
    .galaxy-keyhole { display: none; }
    .galaxy-constellation {
      position: relative; opacity: 1;
      padding: 36px 16px;
      display: flex; flex-wrap: wrap;
      align-items: center; justify-content: center; gap: 10px;
    }
    .const-eyebrow {
      position: relative; left: auto; transform: none; opacity: 1;
      margin-bottom: 24px; width: 100%; text-align: center;
    }
    .const-cta {
      position: relative; bottom: auto; left: auto; transform: none; opacity: 1;
      margin-top: 24px; width: 100%; text-align: center;
    }
    .star {
      position: relative;
      left: auto !important; top: auto !important;
      transform: none; opacity: 1;
    }
    .star::before { display: none; }
    .star-img { animation: none; max-width: 76px; max-height: 34px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .galaxy-cube { animation: none; }
    .star-img    { animation: none; }
    .star, .star::before, .star-img,
    .const-eyebrow, .const-cta, .galaxy-glow { transition: none; }
  }
</style>
