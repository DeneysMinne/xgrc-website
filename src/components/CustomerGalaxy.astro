  { file: 'TSEBO.jpg',              name: 'Tsebo' },
  { file: 'UNITRANS.png',           name: 'Unitrans' },
  { file: 'Fraser-Alexander.jpg',   name: 'Fraser Alexander' },
  { file: 'SERVEST.jpg',            name: 'Servest' },
  { file: 'SUPERCARE.jpg',          name: 'Supercare' },
